{
  "name": "@smartimpact-it/locations-map",
  "version": "1.4.0",
  "description": "A library to display locations on a map.",
  "scripts": {
    "watch": "webpack --progress --watch --color --config config/webpack.config.js",
    "start": "cross-env NODE_ENV=development webpack serve --open --config config/webpack.config.js",
    "build": "npm run build:umd && npm run build:esm && npm run build:types",
    "build:vite": "vite build",
    "build:esm": "node tools/cleanup esm && tsc -p config/tsconfig.esm.json && babel ./dist/esm -d ./dist/esm --config-file ./config/babel.config.esm.js && copyfiles -u 1 \"src/**/*.css\" dist/esm",
    "build:umd": "node tools/cleanup umd && webpack --config config/webpack.config.js",
    "build:types": "node tools/cleanup types && copyfiles -u 1 \"src/**/*.d.ts\" dist/types && tsc -p config/tsconfig.types.json",
    "test": "jest --config jestconfig.json --passWithNoTests",
    "format": "prettier --write \"src/**/*.ts\" \"**/*.md\"",
    "format:check": "prettier --list-different \"src/**/**.{js,ts}\" \"**/*.md\"",
    "pretest": "npm run build",
    "lint": "tslint -p tsconfig.json",
    "preversion": "npm run lint",
    "prepublishOnly": "npm test && npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags",
    "typedoc": "typedoc --out docs/ src/"
  },
  "main": "dist/umd/index.js",
  "es2015": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/umd/index.js"
    },
    "./dist/": "./dist/",
    "./src/": "./src/",
    "./utils/": "./utils/",
    "./esm/": "./dist/esm/",
    "./css/": "./dist/css/",
    "./umd/": "./dist/umd/",
    "./types/": "./dist/types/",
    "./main.css": {
      "style": "./dist/css/main.css",
      "import": "./dist/css/main.css",
      "require": "./dist/css/main.css"
    },
    "./GoogleMapsWrapper": {
      "import": "./dist/esm/map-providers/GoogleMaps/GoogleMapsWrapper.js"
    },
    "./GoogleMapsClusteredWrapper": {
      "import": "./dist/esm/map-providers/GoogleMaps/GoogleMapsClusteredWrapper.js"
    },
    "./LeafletMapWrapper": {
      "import": "./dist/esm/map-providers/Leaflet/LeafletMapWrapper.js"
    },
    "./LeafletMapClusteredWrapper": {
      "import": "./dist/esm/map-providers/Leaflet/LeafletMapClusteredWrapper.js"
    },
    "./MapboxMapWrapper": {
      "import": "./dist/esm/map-providers/Mapbox/MapboxMapWrapper.js"
    },
    "./MapboxMapClusteredWrapper": {
      "import": "./dist/esm/map-providers/Mapbox/MapboxMapClusteredWrapper.js"
    },
    "./GoogleMapsGeocoderProvider": {
      "import": "./dist/esm/search-providers/GoogleMapsGeocoderProvider.js"
    },
    "./NominatimProvider": {
      "import": "./dist/esm/search-providers/NominatimProvider.js"
    },
    "./Pagination": {
      "import": "./dist/esm/pagination-provider/Pagination.js"
    },
    "./AdvancedPaginationProvider": {
      "import": "./dist/esm/pagination-provider/AdvancedPaginationProvider.js"
    }
  },
  "directories": {
    "lib": "dist"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "utils/**/*"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "authors": [
    {
      "name": "SmartImpact IT",
      "email": "dev@smartimpact.it",
      "url": "https://smartimpact.fr"
    },
    {
      "name": "Bogdan Barbu",
      "email": "bbarbu@smartimpact.fr"
    }
  ],
  "license": "GPL-3",
  "keywords": [
    "map",
    "stores",
    "locations",
    "google maps",
    "leaflet"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siit-dev/locations-map.git"
  },
  "dependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/list.js": "^2.3.4",
    "@types/lodash": "^4.17.24",
    "@types/markerclustererplus": "^2.1.33"
  },
  "optionalDependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclustererplus": "^1.2.10",
    "@tarekraafat/autocomplete.js": "^10.2.10",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "list.js": "^2.3.1"
  },
  "peerDependencies": {
    "mapbox-gl": "^3.6.0"
  },
  "peerDependenciesMeta": {
    "mapbox-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/helpers": "^7.29.2",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-async-to-generator": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.28.6",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclustererplus": "^1.2.10",
    "@tarekraafat/autocomplete.js": "^10.2.10",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.6",
    "html-webpack-tags-plugin": "^3.0.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "list.js": "^2.3.1",
    "mapbox-gl": "^3.21.0",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.9",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-notifier": "^1.15.0"
  },
  "bugs": {
    "url": "https://github.com/siit-dev/locations-map/issues"
  },
  "homepage": "https://github.com/siit-dev/locations-map",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom"
  }
}
